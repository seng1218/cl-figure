  "permissions": {
    "allow": [
      "Bash(grep -r import.*from c:/Users/HMS/my-figurine-shop/src --include=*.js --include=*.jsx)",
      "Bash(npm list:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(head -100 /c/Users/HMS/my-figurine-shop/src/app/product/[id]/page.js)",
      "Bash(npm run:*)",
      "Bash(node_modules/.bin/opennextjs-cloudflare build:*)",
      "Bash(node_modules/.bin/wrangler deploy:*)",
      "Bash(curl -s -X POST http://localhost:3000/api/subscribe -H \"Content-Type: application/json\" -d '{\"email\":\"test@example.com\",\"name\":\"Test User\"}')",
      "Bash(curl *)",
      "Read(//c/tmp/**)",
      "Read(//c/Users/HMS/**)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(xargs grep *)",
      "Bash(npx next *)",
      "Bash(grep -v \"^$\")",
      "Bash(netstat -ano)",
      "Bash(npx claude-code-templates@latest *)",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm start)",
      "Bash(git commit *)",
      "Bash(xargs wc *)",
      "Bash(git check-ignore *)",
      "Bash(git -C D:/my-figurine-shop status)",
      "Bash(git -C D:/my-figurine-shop diff)",
      "Bash(git -C D:/my-figurine-shop add src/components/LiveActivityToast.js)",
      "Bash(git -C D:/my-figurine-shop commit -m ' *)",
      "Bash(git *)",
      "Skill(update-config)",
      "Bash(npx opennextjs-cloudflare *)"
    ]
  },
  "disabledMcpjsonServers": [
    "web-scraper",
    "system-admin",
    "network-tools"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ -n \"$CLAUDE_TOOL_FILE_PATH\" && -f \"$CLAUDE_TOOL_FILE_PATH\" ]]; then mkdir -p .backups && cp \"$CLAUDE_TOOL_FILE_PATH\" \".backups/$(basename \"$CLAUDE_TOOL_FILE_PATH\").$(date +%Y%m%d_%H%M%S).bak\"; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v semgrep >/dev/null 2>&1; then semgrep --config=auto \"$CLAUDE_TOOL_FILE_PATH\" 2>/dev/null || true; fi; if command -v gitleaks >/dev/null 2>&1; then gitleaks detect --source=\"$CLAUDE_TOOL_FILE_PATH\" --no-git 2>/dev/null || true; fi; if grep -qE '(password|secret|key|token)\\s*=\\s*[\"\\x27][^\"\\x27]{8,}' \"$CLAUDE_TOOL_FILE_PATH\" 2>/dev/null; then echo \"Warning: Potential hardcoded secrets detected in $CLAUDE_TOOL_FILE_PATH\" >&2; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git add \"$CLAUDE_TOOL_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/change-logger.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/change-logger.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python .claude/scripts/context-monitor.py"
  }
}
