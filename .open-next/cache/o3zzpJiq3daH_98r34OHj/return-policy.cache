ue.\"]}],[\"$\",\"li\",null,{\"children\":[\"Await confirmation. We will respond within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"2 business days\"}],\".\"]}],[\"$\",\"li\",null,{\"children\":[\"If approved, ship the item back to the address provided. \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Return shipping cost\"}],\" is borne by the buyer unless the fault is ours.\"]}]]}]]}]]}]\n12:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"7. Refunds\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Upon receipt and inspection of the returned item:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"Approved refunds will be processed within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"7–14 business days\"}],\".\"]}],[\"$\",\"li\",null,{\"children\":[\"Refunds are issued via the \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"original payment method\"}],\" (bank transfer, e-wallet, or platform credit).\"]}],[\"$\",\"li\",null,{\"children\":\"Original shipping fees are non-refundable unless the return is due to our error.\"}]]}]]}]]}]\n13:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"8. Exchanges\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[\"$\",\"p\",null,{\"children\":[\"We do not offer direct exchanges. If your return is approved, a \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"full refund\"}],\" will be issue