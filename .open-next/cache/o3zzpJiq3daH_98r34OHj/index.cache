ransition-all duration-300 bg-white/10 border border-white/20 backdrop-blur-sm\" action=\"/shop\" method=\"GET\"><input type=\"text\" placeholder=\"SEARCH VAULT...\" class=\"bg-transparent border-none outline-none text-[10px] text-white uppercase font-black tracking-widest pl-3 w-28 focus:w-48 transition-all placeholder:text-gray-500\" name=\"q\"/><button type=\"submit\" class=\"flex items-center justify-center ml-1 hover:opacity-70 transition-opacity\" aria-label=\"Search\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-search text-white/80\" aria-hidden=\"true\"><path d=\"m21 21-4.34-4.34\"></path><circle cx=\"11\" cy=\"11\" r=\"8\"></circle></svg></button></form><button aria-label=\"Open cart\" class=\"relative flex items-center gap-2 px-4 py-3 rounded-full transition-all duration-500 shadow-xl\n                bg-white/10 text-white border border-white/20 hover:scale-110 backdrop-blur-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shopping-bag\" aria-hidden=\"true\"><path d=\"M16 10a4 4 0 0 1-8 0\"></path><path d=\"M3.103 6.034h17.794\"></path><path d=\"M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z\"></path></svg></button><button aria-label=\"Open menu\" class=\"md:hidden relative p-3 rounded-full transition-all duration-500 shadow-xl\n                bg-white/10 text-white border border-white/20 hover:scale-110 backdrop-blur-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"l