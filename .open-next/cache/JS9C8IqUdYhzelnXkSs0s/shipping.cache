5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\",\"key\":\"oel41y\"}],[\"path\",{\"d\":\"m9 12 2 2 4-4\",\"key\":\"dzmm74\"}]],\"className\":\"lucide-shield-check\",\"size\":14}],\" Legal\"]}],[\"$\",\"h1\",null,{\"className\":\"text-5xl md:text-6xl font-black text-white italic tracking-tighter leading-none mb-4\",\"children\":\"SHIPPING POLICY\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs font-bold uppercase tracking-widest\",\"children\":\"Effective: 1 May 2026  ·  Jurisdiction: Malaysia\"}]]}],[\"$\",\"div\",null,{\"className\":\"prose-invert\",\"children\":[[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"1. Delivery Coverage\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"Vault 6 Studios ships to \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"all addresses within Malaysia\"}],\", including Peninsular Malaysia, Sabah, and Sarawak. We do not currently offer international shipping.\"]}],[\"$\",\"p\",null,{\"children\":\"P.O. Box addresses are not accepted as delivery addresses due to the fragile and high-value nature of our products. A physical street address with a valid contact number is required for all orders.\"}]]}]]}],\"$Ld\",\"$Le\",\"$Lf\",\"$L10\",\"$L11\",\"$L12\",\"$L13\",\"$L14\",\"$L15\",\"$L16\",\"$L17\"]}],\"$L18\"]}]}],null,\"$L19\"]}],{},null,false]},null,false]},null,false],\"$L1a\",false]],\"m\":\"$undefined\",\"G\":[\"$1b\",[]],\"s\":false,\"S\":true}\n1c:I[24431,[],\"OutletBoundary\"]\n1e:I[15278,[],\"AsyncMetadataOutlet\"]\n20:I[24431,[],\"ViewportBoundary\"]\n22:I[24431,[],\"MetadataBoundary\"]\n23:\"$Sreact.suspense\"\nd:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"2. Courier Partners\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We ship via the following courier partners. The assigned courier is selected at our discretion based on your delivery zone, parcel weight, and service availability:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2 text-gray-500\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"J&T Express\"}],\" — Nationwide coverage, standard parcels\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Pos Laju (Poslaju)\"}],\" — Nationwide coverage including rural zones\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"NinjaVan\"}],\" — Peninsular Malaysia, urban delivery\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"DHL eCommerce\"}],\" — Premium service for high-value items\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Shopee Express / Lalamove\"}],\" — Supplementary service for certain zones\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-2\",\"children\":\"We reserve the right to change courier providers at any time without prior notice. Regardless of courier assignment, the service standards in this policy apply in full.\"}]]}]]}]\ne:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"3. Processing Time\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Processing time is the period between order payment confirmation and the parcel being handed to the courier.\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Ready Stock items:\"}],\" Packed and dispatched within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"1–2 business days\"}],\" of payment confirmation.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Pre-Order items:\"}],\" Dispatched upon arrival from the manufacturer/distributor. See Section 7 of our \",[\"$\",\"$Lb\",null,{\"href\":\"/terms\",\"className\":\"text-blue-500 hover:text-white transition-colors\",\"children\":\"Terms & Conditions\"}],\" for pre-order delivery timelines.\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs\",\"children\":\"Business days are Monday to Friday, excluding Malaysian public holidays (Federal and Selangor). Orders placed after 3:00 PM on a business day or on weekends/public holidays will begin processing on the next business day.\"}]]}]]}]\nf:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"4. Estimated Delivery Timeframes\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"The following are estimated delivery windows after dispatch. These are guidelines provided by the respective couriers and are not guaranteed:\"}],[\"$\",\"div\",null,{\"className\":\"overflow-x-auto\",\"children\":[\"$\",\"table\",null,{\"className\":\"w-full text-sm border-collapse\",\"children\":[[\"$\",\"thead\",null,{\"children\":[\"$\",\"tr\",null,{\"className\":\"border-b border-gray-800\",\"children\":[[\"$\",\"th\",null,{\"className\":\"text-left text-white font-black text-[10px] uppercase tracking-widest py-3 pr-6\",\"children\":\"Region\"}],[\"$\",\"th\",null,{\"className\":\"text-left text-white font-black text-[10px] uppercase tracking-widest py-3 pr-6\",\"children\":\"Estimated Delivery\"}]]}]}],[\"$\",\"tbody\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"tr\",null,{\"className\":\"border-b border-gray-900\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-3 pr-6 text-gray-400\",\"children\":\"Peninsular Malaysia (major cities)\"}],[\"$\",\"td\",null,{\"className\":\"py-3 text-white font-bold\",\"children\":\"1–3 business days\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-gray-900\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-3 pr-6 text-gray-400\",\"children\":\"Peninsular Malaysia (suburban / rural)\"}],[\"$\",\"td\",null,{\"className\":\"py-3 text-white font-bold\",\"children\":\"2–5 business days\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-gray-900\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-3 pr-6 text-gray-400\",\"children\":\"Sabah & Sarawak (urban)\"}],[\"$\",\"td\",null,{\"className\":\"py-3 text-white font-bold\",\"children\":\"3–7 business days\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-gray-900\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-3 pr-6 text-gray-400\",\"children\":\"Sabah & Sarawak (interior / rural)\"}],[\"$\",\"td\",null,{\"className\":\"py-3 text-white font-bold\",\"children\":\"5–10 business days\"}]]}],[\"$\",\"tr\",null,{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-3 pr-6 text-gray-400\",\"children\":\"Labuan\"}],[\"$\",\"td\",null,{\"className\":\"py-3 text-white font-bold\",\"children\":\"3–7 business days\"}]]}]]}]]}]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-4\",\"children\":\"Delivery timeframes may be extended during peak periods (Hari Raya Aidilfitri, Chinese New Year, Deepavali, year-end festive season) and may be affected by adverse weather, natural events, or nationwide disruptions. We will communicate known delays proactively.\"}]]}]]}]\n10:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"5. Shipping Rates\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Shipping fees are calculated at checkout based on parcel weight, dimensions, and delivery zone. The applicable rate will be clearly displayed before you confirm payment.\"}],[\"$\",\"p\",null,{\"children\":\"For select promotions, free shipping may be offered above a qualifying order value. Promotional shipping terms are stated on the relevant campaign page or announcement banner.\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs\",\"children\":[\"We do not add mark-ups to courier rates. The fee charged reflects the actual shipping cost. Shipping fees are non-refundable except where the return is due to our error, as detailed in our \",[\"$\",\"$Lb\",null,{\"href\":\"/return-policy\",\"className\":\"text-blue-500 hover:text-white transition-colors\",\"children\":\"Return & Refund Policy\"}],\".\"]}]]}]]}]\n11:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"6. Packaging Standards\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We take packaging seriously. All collectible figures are packed to minimise the risk of damage in transit:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Primary protection:\"}],\" Figure boxes are individually wrapped in bubble wrap (minimum 2 layers) and surrounded by foam padding or kraft paper fill.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Outer carton:\"}],\" Parcels are shipped in a corrugated cardboard outer box sized appropriately to prevent movement. Oversized figures may require custom-cut foam inserts.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"MISB / Sealed items:\"}],\" Factory-sealed boxes are never opened for repacking. The sealed item is nested within the outer shipping carton with adequate cushioning.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Multiple items:\"}],\" Orders containing multiple figures are individually padded and secured within a single outer carton where weight permits, or shipped in separate parcels.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Fragile labelling:\"}],\" All parcels are labelled with “FRAGILE — THIS SIDE UP” markings.\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-2\",\"children\":\"Despite our packaging standards, courier handling may cause damage. We strongly recommend examining your parcel for visible external damage before signing for delivery, and noting any damage with the delivery agent.\"}]]}]]}]\n12:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"7. Tracking\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"A tracking number will be sent to you via \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"WhatsApp\"}],\" (or email, where applicable) within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"24 hours\"}],\" of dispatch. You may use this number to track your parcel directly on the courier’s website.\"]}],[\"$\",\"p\",null,{\"children\":\"If you have not received a tracking number within 3 business days of payment confirmation (for Ready Stock items), please contact us immediately.\"}]]}]]}]\n13:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"8. Damaged in Transit\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"If your item arrives visibly damaged due to transit mishandling:\"}],[\"$\",\"ol\",null,{\"className\":\"list-decimal list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"Photograph the \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"outer packaging\"}],\" (before opening), the \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"inner packaging\"}],\", and the \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"damaged item\"}],\" immediately.\"]}],[\"$\",\"li\",null,{\"children\":[\"Contact us via WhatsApp within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"24 hours\"}],\" of delivery with your order reference and the photographs.\"]}],[\"$\",\"li\",null,{\"children\":\"We will lodge a damage claim with the courier on your behalf. Most couriers require claim submission within 7 days of delivery.\"}],[\"$\",\"li\",null,{\"children\":\"Pending the outcome of the courier investigation, we will offer a replacement (subject to stock availability) or a full refund.\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-2\",\"children\":\"Damage claims require photographic evidence. Claims submitted without photos or after the 24-hour window may be rejected by the courier, limiting our ability to compensate.\"}]]}]]}]\n14:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"9. Lost Parcels\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"A parcel is considered lost if it has not been delivered within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"14 calendar days\"}],\" beyond the estimated delivery window and the tracking information shows no movement for 7 or more consecutive days.\"]}],[\"$\",\"p\",null,{\"children\":\"To report a potential lost parcel:\"}],[\"$\",\"ol\",null,{\"className\":\"list-decimal list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Contact us with your order reference and tracking number.\"}],[\"$\",\"li\",null,{\"children\":\"We will file a loss investigation with the courier. Investigations typically take 7–14 business days.\"}],[\"$\",\"li\",null,{\"children\":\"Upon confirmation of loss, we will offer a replacement (subject to stock) or a full refund of the item value plus shipping fees.\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-2\",\"children\":\"Vault 6 Studios assumes responsibility for parcels up to the point of confirmed courier handover. Liability for loss or damage thereafter is subject to the outcome of courier claim procedures.\"}]]}]]}]\n15:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"10. Failed Delivery & Return to Sender\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Delivery may fail due to: incorrect or incomplete address provided, recipient unavailable after multiple delivery attempts, refusal of delivery, or parcel held at a pick-up point left uncollected.\"}],[\"$\",\"p\",null,{\"children\":\"If a parcel is returned to us by the courier:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"We will notify you via WhatsApp upon receipt of the returned parcel.\"}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Re-delivery:\"}],\" You may request re-delivery at your own expense (re-shipping fee applies).\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Refund:\"}],\" If you choose not to have the item re-shipped, we will issue a refund of the item value. Original shipping fees are non-refundable where the return was caused by an incorrect address or failed delivery due to your absence.\"]}]]}],[\"$\",\"p\",null,{\"children\":\"Please ensure your delivery address and contact number are accurate at the time of order. Vault 6 Studios is not liable for failed delivery resulting from incorrect information provided by the buyer.\"}]]}]]}]\n16:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"11. Large & Oversized Items\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Items at 1:4 scale or larger, premium scale figures (over 40cm), or items with exceptionally large original packaging (e.g. figures with large base components or multiple accessories) may incur additional handling or packaging fees, which will be communicated to you prior to dispatch.\"}],[\"$\",\"p\",null,{\"children\":\"For oversize orders, delivery timeframes may be extended by 1–2 additional business days to allow for appropriate packaging preparation.\"}]]}]]}]\n17:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"12. Contact\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"For all shipping enquiries — including tracking, delayed deliveries, damage claims, or failed delivery — please visit our \",[\"$\",\"$Lb\",null,{\"href\":\"/contact\",\"className\":\"text-blue-500 hover:text-white transition-colors\",\"children\":\"Contact Us\"}],\" page.\"]}],[\"$\",\"p\",null,{\"children\":\"Providing your order reference number in your message will allow us to resolve your query faster.\"}]]}]]}]\n18:[\"$\",\"div\",null,{\"className\":\"mt-16 pt-8 border-t border-gray-900 flex flex-wrap gap-6 justify-center\",\"children\":[[\"$\",\"$Lb\",null,{\"href\":\"/privacy-policy\",\"className\":\"text-blue-600 hover:text-white font-black text-[10px] uppercase tracking-[0.3em] transition-colors\",\"children\":\"Privacy Policy\"}],[\"$\",\"$Lb\",null,{\"href\":\"/terms\",\"className\":\"text-blue-600 hover:text-white font-black text-[10px] uppercase tracking-[0.3em] transition-colors\",\"children\":\"Terms & Conditions\"}],[\"$\",\"$Lb\",null,{\"href\":\"/return-policy\",\"className\":\"text-blue-600 hover:text-white font-black text-[10px] uppercase tracking-[0.3em] transition-colors\",\"children\":\"Return Policy\"}]]}]\n19:[\"$\",\"$L1c\",null,{\"children\":[\"$L1d\",[\"$\",\"$L1e\",null,{\"promise\":\"$@1f\"}]]}]\n1a:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L20\",null,{\"children\":\"$L21\"}],null],[\"$\",\"$L22\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$23\",null,{\"fallback\":null,\"children\":\"$L24\"}]}]}]]}]\n21:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1, viewport-fit=cover\"}]]\n1d:null\n25:I[80622,[],\"IconMark\"]\n1f:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"Shipping Policy | Vault 6 Studios | Vault 6 Studios\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Shipping policy for Vault 6 Studios — delivery coverage, timeframes, packaging standards, and lost parcel procedures for Malaysia.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"Vault 6 Studios. | The Vault\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:description\",\"content\":\"Exclusive S-Tier figurines. Highly curated. Zero filler.\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:site_name\",\"content\":\"Vault 6 Studios\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:locale\",\"content\":\"en_MY\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"8\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"9\",{\"name\":\"twitter:title\",\"content\":\"Vault 6 Studios. | The Vault\"}],[\"$\",\"meta\",\"10\",{\"name\":\"twitter:description\",\"content\":\"Exclusive S-Tier figurines. Highly curated. Zero filler.\"}],[\"$\",\"link\",\"11\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\",\"type\":\"image/x-icon\",\"sizes\":\"16x16\"}],[\"$\",\"$L25\",\"12\",{}]],\"error\":null,\"digest\":\"$undefined\"}\n24:\"$1f:metadata\"\n"}