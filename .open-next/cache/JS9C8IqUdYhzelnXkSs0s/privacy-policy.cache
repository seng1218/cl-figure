l,{\"className\":\"text-white font-bold text-xs uppercase tracking-widest mb-2\",\"children\":\"Account & Membership Data (if applicable)\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 text-gray-500\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Member email and name\"}],[\"$\",\"li\",null,{\"children\":\"Password (stored as a cryptographic hash — never in plaintext)\"}],[\"$\",\"li\",null,{\"children\":\"Membership tier, loyalty points, and total spend records\"}],[\"$\",\"li\",null,{\"children\":\"Admin notes and internal correspondence\"}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-white font-bold text-xs uppercase tracking-widest mb-2\",\"children\":\"Technical & Usage Data\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 text-gray-500\",\"children\":[[\"$\",\"li\",null,{\"children\":\"IP address and general geolocation (country/city) — processed by Cloudflare, Inc. as our infrastructure provider\"}],[\"$\",\"li\",null,{\"children\":\"Browser type, operating system, and device type\"}],[\"$\",\"li\",null,{\"children\":\"Pages visited and interaction patterns on this site\"}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-white font-bold text-xs uppercase tracking-widest mb-2\",\"children\":\"Communication Data\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 text-gray-500\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Messages and enquiries submitted via WhatsApp or email\"}],[\"$\",\"li\",null,{\"children\":\"Feedback and reviews you voluntarily submit\"}]]}]]}]]}]]}]]}]\n11:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"3. Legal Basis for Processing (Seven PDPA Principles)\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Under the PDPA 2010, we process personal data in accordance with the following seven Data Protection Principles:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"General Principle:\"}],\" Data is collected only for lawful purposes directly related to our business activities.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Notice & Choice:\"}],\" You are informed of the purposes at or before the point of collection. Consent is obtained for non-essential processing such as direct marketing.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Disclosure:\"}],\" We do not disclose personal data to third parties except as described in Section 5 of this policy, or as required by law.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Security:\"}],\" Appropriate technical and organisational measures are in place to protect data against unauthorised access, loss, or destruction.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Retention:\"}],\" Data is not retained beyond what is necessary for the stated purposes, or the minimum retention period required by law.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Data Integrity:\"}],\" We take reasonable steps to ensure personal data is accurate, complete, and up-to-date.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Access:\"}],\" You have the right to access and correct your personal data as described in Section 9.\"]}]]}]]}]]}]\n12:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"4. How We Use Your Personal Data\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We process your personal data for the following purposes:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"process and fulfil orders\"}],\", including payment verification, packaging, and dispatch\"]}],[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"communicate with you\"}],\" regarding your order status, shipping updates, and returns\"]}],[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"maintain your membership account\"}],\" and administer loyalty points and tier benefits\"]}],[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"send marketing communications\"}],\" (newsletters, promotions) — only where you have subscribed or given explicit consent, and only until you withdraw such consent\"]}],[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"detect and prevent fraud\"}],\", unauthorised transactions, and abuse of our platform\"]}],[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"comply with legal and regulatory obligations\"}],\", including tax records required under the Income Tax Act 1967 and other applicable Malaysian statutes\"]}],[\"$\",\"li\",null,{\"children\":[\"To \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"improve our services\"}],\" through aggregated, anonymised analysis of site usage patterns\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-4\",\"children\":\"We do not use personal data for automated profiling or decision-making that produces legal or similarly significant effects without human review.\"}]]}]]}]\n13:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"5. Disclosure to Third Parties\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We do not sell, rent, or trade your personal data. We share personal data only with the following categories of third parties, strictly on a need-to-know basis:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Curlec Sdn. Bhd. / Razorpay Curlec (Payment Processor):\"}],\" Your payment details are submitted directly to Razorpay Curlec’s secure gateway. We receive only transaction confirmation and payment method type. Razorpay Curlec’s privacy policy governs their handling of payment data.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Courier Partners\"}],\" (J&T Express, PosLaju, NinjaVan, DHL eCommerce, etc.): Your name, delivery address, and phone number are shared with the assigned courier solely for the purpose of parcel delivery.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Cloudflare, Inc. (Infrastructure Provider):\"}],\" Technical data including IP addresses passes through Cloudflare’s network for security, DDoS protection, and content delivery. Cloudflare is certified under SOC 2 Type II and ISO 27001.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Resend, Inc. (Transactional Email):\"}],\" Where email is used to deliver membership credentials or transactional notifications, Resend processes your email address solely for message delivery.\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-4\",\"children\":\"We may disclose personal data if required to do so by law, court order, or directive from a competent Malaysian authority under the PDPA 2010 or the Communications and Multimedia Act 1998.\"}]]}]]}]\n14:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"6. Data Retention\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Order and transaction records:\"}],\" Retained for a minimum of \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"7 years\"}],\" from the date of transaction, in accordance with the Income Tax Act 1967 and the Companies Act 2016 (audit trail requirements).\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Member account data:\"}],\" Retained for the duration of active membership plus \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"2 years\"}],\" after account deletion, to resolve any outstanding disputes.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Newsletter subscription data:\"}],\" Retained until you unsubscribe or withdraw consent.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Communication records:\"}],\" Retained for \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"3 years\"}],\" for dispute resolution purposes.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Technical log data:\"}],\" Retained for up to \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"90 days\"}],\" by Cloudflare per their standard data retention policy.\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs mt-4\",\"children\":\"Upon expiry of the applicable retention period, personal data is deleted or anonymised in accordance with Section 9 of the PDPA 2010.\"}]]}]]}]\n15:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"7. Data Security\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We implement the following technical and organisational security measures:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"All data transmitted between your browser and our site is encrypted using \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"TLS 1.2 or higher (HTTPS)\"}],\".\"]}],[\"$\",\"li\",null,{\"children\":[\"Member passwords are stored as \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"cryptographic hashes\"}],\" (one-way bcrypt or equivalent); no plaintext passwords are stored or accessible to us.\"]}],[\"$\",\"li\",null,{\"children\":[\"Admin access to customer data is protected by a \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"time-limited session token system\"}],\" with no persistent access keys in the codebase.\"]}],[\"$\",\"li\",null,{\"children\":[\"Data is stored on \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Cloudflare Workers KV\"}],\", which operates within Cloudflare’s global infrastructure with physical and logical access controls, SOC 2 Type II certification, and data residency in the APAC region.\"]}],[\"$\",\"li\",null,{\"children\":[\"We apply the principle of \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"least privilege\"}],\": only personnel with a direct operational need can access personal data.\"]}]]}],[\"$\",\"p\",null,{\"children\":\"Despite these measures, no data transmission over the internet can be guaranteed to be 100% secure. We will notify affected individuals and, where required, the relevant authority, within a reasonable time in the event of a data breach that may cause harm.\"}]]}]]}]\n16:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"8. Cookies & Tracking Technologies\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We use minimal cookies:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Session cookie (admin_session):\"}],\" An HTTP-only, Secure, SameSite=Strict cookie used exclusively for administrative authentication. Not set for regular shoppers.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Cloudflare security cookies:\"}],\" Cloudflare may set cookies (e.g. \",[\"$\",\"code\",null,{\"className\":\"text-blue-400 text-xs\",\"children\":\"__cf_bm\"}],\") for bot detection and DDoS mitigation. These are strictly functional and not used for advertising.\"]}]]}],[\"$\",\"p\",null,{\"children\":\"We do not use third-party advertising cookies, social media tracking pixels, or behavioural analytics tools (e.g. Google Analytics, Facebook Pixel).\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs\",\"children\":\"You may control cookies via your browser settings. Disabling functional cookies may affect the checkout experience.\"}]]}]]}]\n17:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"9. Your Rights\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Under the PDPA 2010, you have the following rights regarding your personal data:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Right of Access (Section 30, PDPA):\"}],\" You may request a copy of the personal data we hold about you. We will respond within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"21 days\"}],\" of receipt of a valid written request.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Right of Correction (Section 34, PDPA):\"}],\" You may request correction of inaccurate or incomplete personal data. We will correct or supplement the data within \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"21 days\"}],\" or notify you if we are unable to do so.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Right to Withdraw Marketing Consent (Section 38, PDPA):\"}],\" You may opt out of direct marketing at any time by contacting us or using the unsubscribe link in any marketing email. Withdrawal does not affect the lawfulness of prior processing.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"Right to Restrict Processing:\"}],\" In limited circumstances, you may request that we restrict processing of your data while a dispute or correction request is pending.\"]}]]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"For EU/EEA Residents (GDPR):\"}],\" In addition to the above, you have the right to data portability (Article 20), the right to object to processing based on legitimate interests (Article 21), and the right to lodge a complaint with your local data protection supervisory authority.\"]}],[\"$\",\"p\",null,{\"children\":[\"To exercise any of these rights, contact us via WhatsApp or email with subject line \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"“PDPA Data Request”\"}],\". We may require you to verify your identity before processing the request.\"]}]]}]]}]\n18:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"10. International Data Transfers\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Your personal data may be processed by Cloudflare, Inc. on servers located in Singapore and other APAC jurisdictions. Cloudflare participates in cross-border data transfer frameworks and maintains Standard Contractual Clauses (SCCs) where applicable.\"}],[\"$\",\"p\",null,{\"children\":\"We do not transfer personal data outside Malaysia to countries without adequate data protection laws without ensuring appropriate safeguards are in place, in compliance with Section 129 of the PDPA 2010.\"}]]}]]}]\n19:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"11. Children's Privacy\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[\"$\",\"p\",null,{\"children\":[\"Our services are not directed at individuals under the age of \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"18\"}],\". We do not knowingly collect personal data from minors. If you believe we have inadvertently collected data from a person under 18, please contact us immediately for deletion.\"]}]}]]}]\n1a:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"12. Changes to This Policy\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"We may update this Privacy Policy from time to time. Material changes will be notified via a site announcement banner or email (for registered members) at least \",[\"$\",\"strong\",null,{\"className\":\"text-white\",\"children\":\"14 days\"}],\" before the change takes effect. Continued use of our services after the effective date constitutes acceptance of the revised policy.\"]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs\",\"children\":\"All prior versions of this policy are archived and available on request.\"}]]}]]}]\n1b:[\"$\",\"div\",null,{\"className\":\"border-b border-gray-900 pb-10 mb-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xs font-black uppercase tracking-[0.4em] text-blue-600 mb-4\",\"children\":\"13. Contact & Data Officer\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-400 text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"For all data protection enquiries, access requests, correction requests, or complaints, please visit our \",[\"$\",\"$Lb\",null,{\"href\":\"/contact\",\"className\":\"text-blue-500 hover:text-white transition-colors\",\"children\":\"Contact Us\"}],\" page.\"]}],[\"$\",\"p\",null,{\"className\":\"text-gray-500 text-xs\",\"children\":\"Vault 6 Studios operates as a private seller of collectible figures, registered and operating within Malaysia.\"}]]}]]}]\n1c:[\"$\",\"div\",null,{\"className\":\"mt-16 pt-8 border-t border-gray-900 flex flex-wrap gap-6 justify-center\",\"children\":[[\"$\",\"$Lb\",null,{\"href\":\"/terms\",\"className\":\"text-blue-600 hover:text-white font-black text-[10px] uppercase tracking-[0.3em] transition-colors\",\"children\":\"Terms & Conditions\"}],[\"$\",\"$Lb\",null,{\"href\":\"/shipping\",\"className\":\"text-blue-600 hover:text-white font-black text-[10px] uppercase tracking-[0.3em] transition-colors\",\"children\":\"Shipping Policy\"}],[\"$\",\"$Lb\",null,{\"href\":\"/return-policy\",\"className\":\"text-blue-600 hover:text-white font-black text-[10px] uppercase tracking-[0.3em] transition-colors\",\"children\":\"Return Policy\"}]]}]\n1d:[\"$\",\"$L20\",null,{\"children\":[\"$L21\",[\"$\",\"$L22\",null,{\"promise\":\"$@23\"}]]}]\n1e:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L24\",null,{\"children\":\"$L25\"}],null],[\"$\",\"$L26\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$27\",null,{\"fallback\":null,\"children\":\"$L28\"}]}]}]]}]\n25:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1, viewport-fit=cover\"}]]\n21:null\n29:I[80622,[],\"IconMark\"]\n23:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"Privacy Policy | Vault 6 Studios | Vault 6 Studios\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Privacy Policy for Vault 6 Studios — compliant with Malaysia Personal Data Protection Act 2010 (PDPA) and GDPR principles.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"Vau